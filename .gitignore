# ---------------------------------------------------------------------------
# EduAI — root .gitignore (covers both backend/ and frontend/)
# ---------------------------------------------------------------------------

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Environment variables (never commit secrets / API keys / DB URIs)
.env
.env.*
!.env.example

# ---- Backend (Express + TypeScript) ----
# Compiled TypeScript output
backend/dist/
dist/
# Runtime-generated artifacts
backend/uploads/
backend/generated_papers/
uploads/
generated_papers/

# ---- Frontend (Next.js) ----
.next/
out/
build/
next-env.d.ts

# TypeScript
*.tsbuildinfo

# Testing / coverage
coverage/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/*
!.vscode/extensions.json

# Deployment
.vercel
